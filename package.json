{
  "name": "tokenleader",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted token-usage leaderboard for Claude Code, Codex CLI, and Cursor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anaralabs/tokenleader"
  },
  "bugs": "https://github.com/anaralabs/tokenleader/issues",
  "keywords": [
    "claude-code",
    "codex",
    "cursor",
    "token-usage",
    "leaderboard",
    "self-hosted",
    "bun",
    "hono"
  ],
  "type": "module",
  "scripts": {
    "dev:server": "bun run --hot src/server/main.ts",
    "dev:daemon": "bun run src/daemon/main.ts",
    "build:server": "bun build src/server/main.ts --compile --outfile bin/anara-leaderboard-server",
    "build:daemon": "bash scripts/build-daemon.sh '' bin/anara-leaderboard",
    "build:daemon-arm64": "bash scripts/build-daemon.sh bun-darwin-arm64 bin/anara-leaderboard-arm64",
    "build:daemon-x64": "bash scripts/build-daemon.sh bun-darwin-x64 bin/anara-leaderboard-x64",
    "build": "bun run build:server && bun run build:daemon",
    "build:all": "bun run build:server && bun run build:daemon && bun run build:daemon-arm64 && bun run build:daemon-x64",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome ci ."
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": []
}
