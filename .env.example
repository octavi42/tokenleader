# tokenleader server configuration
# Copy to .env (or set in your platform's env UI). EVERYTHING here is optional —
# the server boots with zero env vars. Real environment variables always override
# values in this file (Bun loads .env natively; no dotenv needed).
#
# Daemon (teammate-machine) settings are NOT configured here — the installer
# writes them into the LaunchAgent plist.

# --- Basics -----------------------------------------------------------------
# PORT=8787
# TOKENLEADER_HOST=0.0.0.0
# Team name shown in the dashboard header and installer banner. Unset = wordmark only.
# (Logo + favicon are file-based, not env-based: drop logo.svg / favicon.svg
#  into <data-dir>/brand/ and the /brand/* routes pick them up within 5 min —
#  no redeploy. See docs/configuration.md "Branding".)
# TOKENLEADER_TEAM_NAME=acme
# Root dir for the SQLite DB + mirrored binaries. Point this at your volume.
# Default: ~/Library/Application Support/tokenleader (macOS),
#          $XDG_DATA_HOME/tokenleader (Linux), /data (Docker image).
# TOKENLEADER_DATA_DIR=/data
# Fine-grained overrides (rarely needed; derived from DATA_DIR):
# TOKENLEADER_DB=/data/tokenleader.sqlite
# TOKENLEADER_BINARY_CACHE_DIR=/data/binaries
# Public URL of this server, no trailing slash. STRONGLY recommended in production
# (otherwise inferred from request headers, which clients can spoof for /install).
# TOKENLEADER_SERVER_URL=https://leaderboard.example.com
# Server version shown in /stats/admin. Set by the Docker image / release
# pipeline — don't set by hand (defaults to the built-in package.json version).
# TOKENLEADER_SERVER_VERSION=

# --- Auth ---------------------------------------------------------------------
# Admin token (destructive routes, POST /admin/clear). Unset disables them.
# TOKENLEADER_ADMIN_TOKEN=
# Require a token to VIEW the dashboard (/, /stats, /stats/*). Unset = public.
# TOKENLEADER_DASHBOARD_TOKEN=
# Require a bearer token for /api/v1/*. Unset = follows the dashboard posture.
# TOKENLEADER_API_TOKEN=
# Join code for NEW leaderboard handles: when set, the first /ingest claim of a
# username must present it (the installer's --join flag); already-claimed users
# are unaffected. Unset = open TOFU (fine on a LAN/tailnet).
# TOKENLEADER_JOIN_TOKEN=

# --- Daemon binary mirror (auto-updates for your team) --------------------------
# Repo to mirror daemon releases from (`owner/repo`). The mirror needs BOTH the
# repo and a token (unauthenticated mirroring is a follow-up); without them
# /manifest.json and /bin/* will 503 and daemon auto-update is dark.
# TOKENLEADER_GH_REPO=your-org/leaderboard
# TOKENLEADER_GH_TOKEN=
# TOKENLEADER_MIRROR_INTERVAL_SEC=900

# --- Cursor mirror (optional, OFF by default) -----------------------------------
# Needs a Cursor Teams admin API key.
# TOKENLEADER_CURSOR_TOKEN=
# TOKENLEADER_CURSOR_INTERVAL_SEC=900
# Map Cursor account emails to leaderboard names (JSON), or use _FILE for a path
# (the file wins entirely; REQUIRED when the Cursor token is set).
# TOKENLEADER_CURSOR_USER_MAP={"alice@example.com":"alice","bob@example.com":"bob"}
# TOKENLEADER_CURSOR_USER_MAP_FILE=
